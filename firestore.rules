rules_version = '2';

// PocketBirds Firestore security rules.
//
// Replaces the old wide-open test-mode rules (allow read, write: if true).
// Anything not matched below is denied by default. Cloud Functions use the
// Admin SDK, which bypasses these rules, so server-maintained fields
// (hootCount, recentHooters, commentCount, topComment, activity docs) are
// written server-side and don't need client write permission here.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function myUid() { return request.auth.uid; }

    // Admin allowlist (keep in sync with constants/admin.ts). Used to gate the
    // global-first verification write on the `sightings` collection. Hardcoded
    // by uid so there's no self-settable flag to escalate against.
    // [0] Alex (akeats97@gmail.com), [1] Victoria (vmvickymin@gmail.com).
    function isAdmin() {
      return isSignedIn() && request.auth.uid in [
        'ZerkNpeAERSwmptlrPeboR5TASs2',
        'bvorXp0fC1QmhiUQM4ssoQcsodr1'
      ];
    }

    // Collection-group read for hoots. HootsContext runs a
    // collectionGroup('hoots') query, and collection-group queries are only
    // authorized by a recursive-wildcard rule — the path-scoped rule nested
    // under /sightings/{id}/hoots does NOT cover them. Writes stay governed by
    // the nested rule below (which enforces doc-id == uid + canEngage).
    match /{path=**}/hoots/{hooterUid} {
      allow read: if isSignedIn();
    }

    // Username -> uid map. The availability check during signup runs BEFORE
    // the new user is authenticated, so a single-doc read must be public.
    // Bulk listing (friend search) requires auth. Usernames are immutable once
    // claimed (an overwrite is an update, which is denied), which keeps them
    // unique at the rules layer.
    match /usernames/{username} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == myUid();
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == myUid();
    }

    // User profiles. Readable by any signed-in user (friends read each other's
    // username/profile). Writable only by the owner. The bio (HEP-11) is the
    // one free-text field on the doc, so it gets a type + length cap here.
    match /users/{uid} {
      function bioOk() {
        return !('bio' in request.resource.data)
               || (request.resource.data.bio is string
                   && request.resource.data.bio.size() <= 80);
      }
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && uid == myUid() && bioOk();
      allow delete: if isSignedIn() && uid == myUid();

      // Per-friend notification preferences, owned by the {uid} user.
      match /notificationPrefs/{followedUid} {
        allow read, write: if isSignedIn() && uid == myUid();
      }

      // Block list (PL-2), owned by the {uid} user. The blocked doc's
      // existence is what canEngage() checks on the sightings tree; the
      // both-direction follow-edge teardown happens in the blockUser callable
      // (Admin SDK), since you can't delete the other user's edge yourself.
      // Unblock = the owner deletes the doc.
      match /blocked/{blockedUid} {
        allow read, write: if isSignedIn() && uid == myUid();
      }

      // Activity inbox (Phase 2.5): written by Cloud Functions (Admin SDK).
      // The owner may read it and flip the read flag; clients never create.
      match /activity/{activityId} {
        allow read, update, delete: if isSignedIn() && uid == myUid();
        allow create: if false;
      }
    }

    // Follow graph: following/{follower}/following/{followed}.
    // You manage only your own following list.
    match /following/{followerUid}/following/{followedUid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && followerUid == myUid();
    }

    // Collection-group read over `following` so a signed-in user can query the
    // whole graph (getConnections / getFollowCounts derive a user's FOLLOWERS
    // from it — there's no reverse index). Read-only; writes stay gated by the
    // path rule above. Collection-group queries require this recursive-wildcard
    // match in addition to the fixed path rule.
    match /{path=**}/following/{followedUid} {
      allow read: if isSignedIn();
    }

    // Sightings (and the bug-report / feature-request entries that ride the
    // same pipeline). Owner-only writes; any signed-in user may read (the app
    // shows friends' sightings and filters by the follow graph client-side).
    match /sightings/{sightingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == myUid();
      // Owner may edit their own sighting, but NOT the verification fields —
      // those are admin-only, so a user can't self-confirm a sighting (e.g.
      // verify their own joke log). An admin may touch ANY sighting, but ONLY
      // the verification + globalFirst fields — never the species, photo, or
      // anything else. (globalFirst is admin-writable because verifying a
      // sighting recomputes the species' global-first holder, which can reassign
      // the gold across users.) `hidden` is the PL-2 moderation soft-hide:
      // admin-only both ways, so a reported post can be pulled from feeds
      // without deleting the owner's data, and the owner can't unhide it.
      allow update: if isSignedIn() && (
        (resource.data.userId == myUid()
          && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['verified', 'verifiedBy', 'verifiedAt', 'hidden']))
        || (isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['verified', 'verifiedBy', 'verifiedAt', 'globalFirst', 'hidden']))
      );
      allow delete: if isSignedIn() && resource.data.userId == myUid();

      function sightingOwner() {
        return get(/databases/$(database)/documents/sightings/$(sightingId)).data.userId;
      }
      function followsOwner(ownerUid) {
        return exists(/databases/$(database)/documents/following/$(myUid())/following/$(ownerUid));
      }
      // PL-2: an owner's block bars the blocked user from engaging on their
      // sightings, no matter what the follow graph says.
      function blockedByOwner(ownerUid) {
        return exists(/databases/$(database)/documents/users/$(ownerUid)/blocked/$(myUid()));
      }
      // You may engage (hoot / comment / propose) on your own sighting or one
      // by someone you follow who hasn't blocked you.
      function canEngage() {
        return isSignedIn() && (
          sightingOwner() == myUid()
          || (followsOwner(sightingOwner()) && !blockedByOwner(sightingOwner()))
        );
      }

      // Hoots: doc id == hooter's uid (one hoot per user, structurally).
      match /hoots/{hooterUid} {
        allow read: if isSignedIn();
        allow create: if hooterUid == myUid()
                      && request.resource.data.uid == myUid()
                      && canEngage();
        allow delete: if hooterUid == myUid();
      }

      // Comments (Phase 2): author posts on own/followed sightings; the author
      // or the sighting owner may delete.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if request.resource.data.uid == myUid()
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 500
                      && canEngage();
        allow delete: if isSignedIn()
                      && (resource.data.uid == myUid() || sightingOwner() == myUid());

        // Comment hoots: doc id == hooter's uid (one per user, structurally).
        // Same 'hoots' collection group as sighting/proposal hoots, so the
        // recursive-wildcard read rule at the top also covers reads here.
        match /hoots/{hooterUid} {
          allow read: if isSignedIn();
          allow create: if hooterUid == myUid()
                        && request.resource.data.uid == myUid()
                        && canEngage();
          allow delete: if hooterUid == myUid();
        }
      }

      // Community ID proposals (Mystery Bird only — enforced client-side; the
      // rules just gate the engagement graph). Counters (hootCount on the
      // proposal; proposalCount / leadingProposal on the parent sighting) are
      // written only by Cloud Functions via the Admin SDK, so they're absent
      // from every client allow-list below.
      match /proposals/{proposalId} {
        allow read: if isSignedIn();

        // Anyone who follows the owner (or the owner) may propose. uid must be
        // yours, species a non-empty string, and the count must start at 0.
        allow create: if request.resource.data.uid == myUid()
                      && request.resource.data.species is string
                      && request.resource.data.species.size() > 0
                      && request.resource.data.hootCount == 0
                      && canEngage();

        // Owner-only accept: the only client update permitted is flipping
        // `accepted` to true, and only by the sighting owner.
        allow update: if sightingOwner() == myUid()
                      && request.resource.data.diff(resource.data).changedKeys().hasOnly(['accepted'])
                      && request.resource.data.accepted == true;

        // Proposer may withdraw their own; the sighting owner may remove any.
        allow delete: if isSignedIn()
                      && (resource.data.uid == myUid() || sightingOwner() == myUid());

        // Agreement hoots: doc id == hooter's uid (one per user, structurally).
        // These live in the same 'hoots' collection group as sighting hoots, so
        // the recursive-wildcard read rule at the top also covers reads here.
        match /hoots/{hooterUid} {
          allow read: if isSignedIn();
          allow create: if hooterUid == myUid()
                        && request.resource.data.uid == myUid()
                        && canEngage();
          allow delete: if hooterUid == myUid();
        }
      }
    }

    // Moderation reports (PL-2). Any signed-in user may file one about a user
    // or a piece of content; only admins can read or clear them (action is
    // manual and human, per the PRD's side-project sustainability rule). The
    // onReportCreated function pushes admins so nothing sits unseen.
    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.resource.data.reporter == myUid()
                    && request.resource.data.targetType in ['user', 'sighting', 'comment', 'proposal']
                    && request.resource.data.targetId is string
                    && request.resource.data.targetId.size() > 0
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 1000;
      allow read, delete: if isAdmin();
      allow update: if false;
    }
  }
}
